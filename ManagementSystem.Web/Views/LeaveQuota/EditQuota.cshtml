@model LeaveQuotaEditVM

@{
    ViewData["Title"] = "Edit Leave Quota";
}
<h1>Editing @Model.LeaveType?.Name for @Model.Employee.FirstName @Model.Employee.LastName</h1>
<hr />
<br/>
<div class="row">
    <div class="col-md-12">
        <form asp-action="EditQuota">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-formaction="LeaveType.Id"/>
            <input type="hidden" asp-for="Employee.Id" />
            <div class="form-group">
                <label asp-for="NumberOfDays" class="control-label"></label>
                <input asp-for="NumberOfDays" class="form-control" />
                <span asp-validation-for="NumberOfDays" class="text-danger"></span>
            </div>
            <div class="form-group">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
